{
  "name": "lanchat",
  "version": "1.0.0",
  "description": "局域网聊天室 CLI 程序 - 基于 TCP 的全屏终端聊天应用",
  "main": "dist/server/index.js",
  "bin": {
    "lanchat-server": "dist/server/index.js",
    "lanchat": "dist/client/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "tsc -p tsconfig.client.json",
    "start:server": "node dist/server/index.js",
    "start:client": "node dist/client/index.js",
    "dev:server": "ts-node src/server/index.ts",
    "dev:client": "ts-node src/client/index.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "security": "npm audit",
    "pkg:server": "echo \"Skipping pkg due to network issues - building code bundle\"",
    "pkg:client": "echo \"Skipping pkg due to network issues - building code bundle\"",
    "pack:dist": "node scripts/package-dist.js",
    "build:dist": "npm run build:server && npm run build:client && npm run test && npm run pkg:server && npm run pkg:client && npm run pack:dist"
  },
  "keywords": [
    "chatroom",
    "tcp",
    "tls",
    "cli",
    "tui"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "blessed": "^0.1.81",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^14.0.0",
    "winston": "^3.11.0"
  },
  "optionalDependencies": {
    "argon2": "^0.31.2",
    "better-sqlite3": "^9.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/blessed": "^0.1.25",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.24",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "adm-zip": "^0.5.17",
    "archiver": "^8.0.0",
    "eslint": "^8.57.0",
    "jest": "^30.4.2",
    "pkg": "^5.8.1",
    "ts-jest": "^29.4.11",
    "typescript": "^5.4.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
